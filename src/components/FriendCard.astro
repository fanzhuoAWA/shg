---
export interface FriendCardProps {
  name: string;
  avatar: string;
  description: string;
  url: string;
  type?: "friend" | "tech" | "contributor";
}

const { name, avatar, description, url, type = "friend" } = Astro.props as FriendCardProps;

import { Image } from "astro:assets";
import { Icon } from "astro-icon/components";

const iconName = {
  friend: "lucide:users",
  tech: "lucide:code-2",
  contributor: "lucide:git-pull-request",
}[type];
---

<div class="friend-card-wrapper">
  <a href={url} target="_blank" rel="noopener noreferrer" class="card-link">
    <div class="card-gradient">
      <div class="avatar-wrapper">
        <div class="avatar-ring">
          {avatar ? (
            <Image src={avatar} width={64} height={64} alt={name} class="avatar-img" />
          ) : (
            <div class="avatar-placeholder">{name.charAt(0)}</div>
          )}
        </div>
      </div>
      <h3 class="card-name">{name}</h3>
      <div class="divider"></div>
      <p class="card-desc">{description}</p>
    </div>
    <div class="card-footer">
      <div class="visit-btn">
        <Icon name={iconName} class="visit-icon" />
        <span>访问主页</span>
      </div>
    </div>
  </a>
</div>

<style>
/* 基础样式（不包含动态背景色，由 JS 统一设置） */
.friend-card-wrapper {
  border-radius: 1rem;
  overflow: hidden;
  box-shadow: 0 4px 6px -1px rgba(0, 0, 0, 0.1);
  transition: all 0.3s ease;
  border: 1px solid rgba(0,0,0,0.1);
}
.friend-card-wrapper:hover {
  transform: translateY(-4px);
  box-shadow: 0 20px 25px -5px rgba(0, 0, 0, 0.1);
}
.card-gradient {
  padding: 1rem;
  display: flex;
  flex-direction: column;
  align-items: center;
}
.avatar-wrapper {
  margin-bottom: 0.75rem;
}
.avatar-ring {
  width: 64px;
  height: 64px;
  border-radius: 9999px;
  overflow: hidden;
  box-shadow: 0 0 0 2px var(--theme-color-border, rgba(59,130,246,0.3)), 0 0 0 4px #ffffff;
}
.avatar-img {
  width: 100%;
  height: 100%;
  object-fit: cover;
}
.avatar-placeholder {
  width: 100%;
  height: 100%;
  display: flex;
  align-items: center;
  justify-content: center;
  background: var(--theme-color, #3b82f6);
  color: white;
  font-size: 1.5rem;
  font-weight: bold;
}
.card-name {
  font-weight: 700;
  text-align: center;
  margin: 0 0 0.25rem 0;
}
.divider {
  width: 100%;
  height: 1px;
  margin: 0.5rem 0;
}
.card-desc {
  font-size: 0.875rem;
  text-align: center;
  line-height: 1.4;
  height: 2.8em;
  overflow: hidden;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
}
.card-footer {
  padding: 0.5rem;
  display: flex;
  justify-content: center;
  border-top: 1px solid;
}
.visit-btn {
  display: flex;
  align-items: center;
  gap: 4px;
  font-size: 0.75rem;
}
.visit-icon {
  width: 14px;
  height: 14px;
}
</style>

<script>
// 获取主题色（基于 Fuwari 的 --hue）
function getThemeColor() {
  const hue = getComputedStyle(document.documentElement).getPropertyValue('--hue').trim() || '195';
  return `hsl(${hue}, 100%, 50%)`;
}

// 为所有卡片更新样式
function updateAllCards() {
  const isDark = document.documentElement.classList.contains('dark');
  const themeColor = getThemeColor();
  const themeColorLight = `hsla(${getComputedStyle(document.documentElement).getPropertyValue('--hue').trim() || '195'}, 100%, 50%, 0.2)`;

  document.querySelectorAll('.friend-card-wrapper').forEach(cardWrapper => {
    const gradientDiv = cardWrapper.querySelector('.card-gradient');
    if (!gradientDiv) return;

    if (isDark) {
      cardWrapper.style.backgroundColor = '#1e1e2f';
      cardWrapper.style.borderColor = 'rgba(255,255,255,0.1)';
      gradientDiv.style.background = `linear-gradient(135deg, ${themeColorLight}, #1e1e2f)`;
      gradientDiv.style.color = '#f3f4f6';
      cardWrapper.querySelector('.card-name').style.color = '#f3f4f6';
      cardWrapper.querySelector('.divider').style.backgroundColor = '#374151';
      cardWrapper.querySelector('.card-desc').style.color = '#9ca3af';
      cardWrapper.querySelector('.card-footer').style.borderTopColor = '#374151';
      cardWrapper.querySelector('.visit-btn').style.color = themeColor;
      const avatarRing = cardWrapper.querySelector('.avatar-ring');
      if (avatarRing) avatarRing.style.boxShadow = `0 0 0 2px ${themeColor}30, 0 0 0 4px #1e1e2f`;
    } else {
      cardWrapper.style.backgroundColor = '#ffffff';
      cardWrapper.style.borderColor = 'rgba(0,0,0,0.1)';
      gradientDiv.style.background = `linear-gradient(135deg, ${themeColorLight}, #ffffff)`;
      gradientDiv.style.color = '#1f2937';
      cardWrapper.querySelector('.card-name').style.color = '#1f2937';
      cardWrapper.querySelector('.divider').style.backgroundColor = '#e5e7eb';
      cardWrapper.querySelector('.card-desc').style.color = '#4b5563';
      cardWrapper.querySelector('.card-footer').style.borderTopColor = '#e5e7eb';
      cardWrapper.querySelector('.visit-btn').style.color = themeColor;
      const avatarRing = cardWrapper.querySelector('.avatar-ring');
      if (avatarRing) avatarRing.style.boxShadow = `0 0 0 2px ${themeColor}30, 0 0 0 4px #ffffff`;
    }
  });
}

// 初始化并监听主题变化
function initThemeObserver() {
  updateAllCards();

  const observer = new MutationObserver(() => {
    updateAllCards();
  });
  observer.observe(document.documentElement, { attributes: true, attributeFilter: ['class'] });

  document.addEventListener('swup:content:replace', () => {
    updateAllCards();
  });
}

if (document.readyState === 'loading') {
  document.addEventListener('DOMContentLoaded', initThemeObserver);
} else {
  initThemeObserver();
}
</script>