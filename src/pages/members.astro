---
import { getEntry, render } from "astro:content";
import Markdown from "@components/misc/Markdown.astro";
import I18nKey from "../i18n/i18nKey";
import { i18n } from "../i18n/translation";
import MainGridLayout from "../layouts/MainGridLayout.astro";

// 读取 spec 集合中的 members 条目
const membersPost = await getEntry("spec", "members");

if (!membersPost) {
	throw new Error("Members page content not found");
}

const { Content } = await render(membersPost);
---
<MainGridLayout title={i18n(I18nKey.members)} description={i18n(I18nKey.members)}>
    <div class="flex w-full rounded-[var(--radius-large)] overflow-hidden relative min-h-32">
        <div class="card-base z-10 px-9 py-6 relative w-full ">
            <Markdown class="mt-2">
                <Content />
            </Markdown>
        </div>
    </div>
</MainGridLayout>